MONGO_CONNECTION=user:password@link/?appName=appName

# Frontend origin allowed for credentialed CORS (cookies).
# Example: http://localhost:3000
WEB_ORIGIN=http://localhost:3000

# Session manager configuration (Go duration strings).
# Examples: 30m, 1h, 12h
SESSION_GC_INTERVAL=30m
SESSION_IDLE_EXPIRATION=1h
SESSION_ABSOLUTE_EXPIRATION=12h

# Session cookie configuration
SESSION_COOKIE_NAME=session
# Optional (set in production to your domain, e.g. example.com)
SESSION_COOKIE_DOMAIN=
# Set true in HTTPS environments
SESSION_COOKIE_SECURE=false
# lax | strict | none
SESSION_COOKIE_SAMESITE=lax
